# Python 仮想環境（環境依存の絶対パスを含むため共有しない・再生成可能）
.venv/
__pycache__/
*.pyc

# 取得した生の境界データ（サイズ大・再ダウンロード可能）
data/raw/

# スクラブ前の生KML（個人情報を含む未加工データ。公開しない。
# マイマップの KML エクスポートで再取得可能）
mosques_raw.kml

# 個人情報スクラブ規則（除去対象の語そのものが個人情報のため公開しない）
scripts/scrub_rules.json

# Notion エクスポート（生データ・個人情報を含む可能性・サイズ大。公開しない）
Export_Mega/

# OS が生成するファイル
.DS_Store

# 資金調達リサーチの作業ファイル（生データ由来・非公開）
funding_work/

# AIセッションのアーカイブ（作業記録・非公開）
AI_Sessions/
